# Public URLs (safe for the browser bundle)
# Local dev:
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
# Test / staging marketing + dashboard (see .env.production):
# NEXT_PUBLIC_APP_URL=https://test.ondial.ai
# NEXT_PUBLIC_API_URL=https://dashboard-test.ondial.ai/api
# Optional — defaults to API origin with /api stripped:
# NEXT_PUBLIC_DASHBOARD_URL=https://dashboard-test.ondial.ai

# Contentful (server-only — do NOT prefix with NEXT_PUBLIC_)
# Use .env.local for local dev + `npm run build` (Next.js does not load .env.development during builds).
CONTENTFUL_SPACE_ID=
CONTENTFUL_GRAPHQL_TOKEN=
CONTENTFUL_ENVIRONMENT=master
