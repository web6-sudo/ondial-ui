# Public URLs (safe for the browser bundle)
# Local dev:
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Test / staging marketing + dashboard (see .env.production):
# NEXT_PUBLIC_APP_URL=https://test.ondial.ai
# NEXT_PUBLIC_API_URL=https://dashboard-test.ondial.ai/api
# Optional — defaults to API origin with /api stripped:
# NEXT_PUBLIC_DASHBOARD_URL=https://dashboard-test.ondial.ai
# site URL (for SEO, sitemap, etc. — defaults to APP_URL if not set):
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Supabase (blog DB backend) ─────────────────────────────────────────
# Get these from: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...          # public — safe for browser (not used server-side for writes)
SUPABASE_SERVICE_KEY=eyJ...       # secret — NEVER expose in browser bundle; server/API routes only

# ─── Upstash Redis (blog caching layer) ─────────────────────────────────────
# Get these from: https://console.upstash.com → Your Database → REST API tab
UPSTASH_REDIS_REST_URL=https://xxxxxxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── SEO CMS protection ─────────────────────────────────────────────────────
# Long random string — login password for /seo/login and signing API sessions.
# Never expose in NEXT_PUBLIC_* vars. Optional: pass as x-admin-token for scripts only.
ADMIN_SECRET=replace-with-a-long-random-secret

# ─── ISR revalidation ────────────────────────────────────────────────────────
# Secret token for the /api/revalidate endpoint
REVALIDATE_SECRET=replace-with-another-long-random-secret
NEXT_PUBLIC_URL=https://www.ondial.ai
